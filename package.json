{
  "name": "pacman-debian",
  "version": "7.2.0",
  "description": "A Debian/Ubuntu package manager using Arch Linux pacman syntax. Manages .deb packages at dpkg level, supports Arch .pkg.tar.zst, AUR helpers (yay), and makepkg. Configurable multi-repo setup.",
  "pacmanVersion": "7.1.0",
  "main": "dist/index.js",
  "bin": {
    "pacman": "./dist/index.js",
    "makepkg": "./dist/makepkg/index.js",
    "pacman-conf": "./dist/scripts/pacman-conf.js",
    "pacman-debian-setup": "./dist/scripts/setup.js"
  },
  "scripts": {
    "build": "tsc && make -s -C lib/pac4deb",
    "build:lib": "make -C lib/pac4deb",
    "setup": "sudo node dist/scripts/setup.js",
    "start": "node dist/index.js",
    "postinstall": "echo 'Run `sudo pacman-debian-setup` to complete installation.'",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["pacman", "debian", "ubuntu", "package-manager", "arch", "aur", "makepkg"],
  "author": "Xbodwf",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xbodwf/pacman-debian.git"
  },
  "bugs": {
    "url": "https://github.com/Xbodwf/pacman-debian/issues"
  },
  "homepage": "https://github.com/Xbodwf/pacman-debian",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "os": ["linux"],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
